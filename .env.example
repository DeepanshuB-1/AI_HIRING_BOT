# ── Ollama (local — no API key needed) ──────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_ANALYSIS_MODEL=llama3.1:8b
OLLAMA_INTERVIEW_MODEL=mistral:7b

# ── Database ─────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:pass@localhost/hiringbot
REDIS_URL=redis://localhost:6379

# ── Twilio ───────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# ── ElevenLabs ───────────────────────────────────────────────────────
ELEVENLABS_API_KEY=your_elevenlabs_key
ELEVENLABS_VOICE_ID=your_voice_id

# ── Deepgram ─────────────────────────────────────────────────────────
DEEPGRAM_API_KEY=your_deepgram_key

# ── SendGrid ─────────────────────────────────────────────────────────
SENDGRID_API_KEY=your_sendgrid_key
FROM_EMAIL=hr@yourcompany.com

# ── App ──────────────────────────────────────────────────────────────
SECRET_KEY=your_jwt_secret_key_change_this_in_production
WEBHOOK_BASE_URL=https://your-ngrok-url.ngrok.io
UPLOAD_DIR=./uploads
AUDIO_CACHE_DIR=./audio_cache
AUTO_REJECT_THRESHOLD=40
CALL_RETRY_COUNT=3
CALL_RETRY_INTERVAL_MINUTES=30
